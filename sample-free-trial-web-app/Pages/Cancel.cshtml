@page
@model CancelModel
@{
    ViewData["Title"] = "Cancel Trial";
}

<div class="cancel-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-8">

                @if (Model.ShowSuccess)
                {
                    @* ── State 2: Cancelled successfully ── *@
                    <div class="cancel-card text-center">
                        <div class="cancel-icon-wrap cancel-icon-success">
                            <i class="bi bi-check-circle-fill"></i>
                        </div>
                        <h1 class="cancel-title">Trial Cancelled</h1>
                        <p class="cancel-subtitle">
                            Your NeuroRevive free trial has been successfully cancelled. You won't be charged.
                        </p>
                        <div class="alert alert-success mt-3" role="status">
                            <i class="bi bi-check-circle me-1"></i>
                            Cancellation confirmed.
                        </div>
                        <p class="cancel-footnote">Changed your mind? You can start a new free trial anytime.</p>
                        <div class="d-flex flex-column gap-2 mt-3">
                            <a asp-page="/Subscribe" class="btn btn-brand-primary">
                                <i class="bi bi-rocket-takeoff me-2"></i>Start a New Trial
                            </a>
                            <a asp-page="/Index" class="btn btn-outline-secondary">
                                <i class="bi bi-house me-2"></i>Back to Home
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    @* ── State 1: Confirm cancellation (no email needed) ── *@
                    <div class="cancel-card">
                        <div class="cancel-icon-wrap cancel-icon-warn">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                        <h1 class="cancel-title text-center">Cancel Your Trial?</h1>
                        <p class="cancel-subtitle text-center">
                            You're about to cancel your NeuroRevive free trial. This will stop your trial and you won't be charged.
                        </p>

                        <div class="cancel-action-row mt-4">
                            <form method="post" asp-page-handler="Cancel">
                                <button type="submit" class="btn btn-cancel-confirm w-100">
                                    <i class="bi bi-x-circle me-2"></i>Yes, cancel my trial
                                </button>
                            </form>
                            <a asp-page="/Index" class="btn btn-outline-secondary w-100 mt-2">
                                <i class="bi bi-heart me-2"></i>Keep my trial
                            </a>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</div>
