{
  "manifest_version": 3,
  "name": "Trial Guard",
  "version": "1.0.0",
  "description": "Detects free-trial sign-ups as you browse, sends daily AI-generated tips to help you get full value, and cancels autonomously when you're ready — powered by Microsoft's Aion-1.0-Instruct, 100% on-device.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["bridge.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Trial Guard"
  },
  "options_page": "options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["download/download.html", "download/download.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
